-        SELECT 1 FROM `match_team_score`
-        WHERE `resultId` = OLD.`resultId`
-          AND `teamId` = (
-                SELECT `team_a_id` FROM `fixture`
-                WHERE `fixtureId` = OLD.`fixtureId`
