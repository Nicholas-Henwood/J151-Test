+                    + "p.isActive AS playerIsActive, "
+                    + "c.clubId AS clubId, "
+                    + "c.clubName AS clubName, "
+                    + "c.location AS clubLocation, "
+                    + "c.homeVenue AS homeVenue, "
+                    + "c.isActive AS clubIsActive, "
+                    + "pos.positionId AS positionId, "
+                    + "pos.positionName AS positionName, "
