-BEGIN
-    IF NEW.`manager_user_id` IS NOT NULL
-       AND NOT (NEW.`manager_user_id` <=> OLD.`manager_user_id`)
-       AND NOT EXISTS (
-            SELECT 1
-            FROM `leagueMembership`
