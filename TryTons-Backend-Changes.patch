+        CHECK (
+            (`status` = 'ACCEPTED'
+                AND `acceptedAt` IS NOT NULL
+                AND `acceptedAt` >= `createdAt`
+                AND `acceptedAt` <= `expiryDate`)
+                OR (`status` <> 'ACCEPTED' AND `acceptedAt` IS NULL)
+            )
+) ENGINE = InnoDB
+  DEFAULT CHARSET = utf8mb4
+  COLLATE = utf8mb4_0900_ai_ci;
