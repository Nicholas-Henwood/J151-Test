+                AND `kickingAbility` BETWEEN 0 AND 100
+                AND `discipline` BETWEEN 0 AND 100
+                AND `consistency` BETWEEN 0 AND 100
+                AND `fitness` BETWEEN 0 AND 100
+                AND `currentForm` BETWEEN 0 AND 100
