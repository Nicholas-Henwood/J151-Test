+    CONSTRAINT `fk_match_team_score_team`
+        FOREIGN KEY (`teamId`) REFERENCES `fantasyTeam` (`teamId`)
+            ON DELETE RESTRICT
+            ON UPDATE CASCADE,
+
+    CONSTRAINT `chk_match_team_score_penalty`
+        CHECK (`transferPenalty` >= 0)
