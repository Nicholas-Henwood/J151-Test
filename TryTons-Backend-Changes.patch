+CREATE TABLE `playerStatistics`
+(
+    `statId`                     VARCHAR(36) NOT NULL,
+    `resultId`                   VARCHAR(36) NOT NULL,
+    `teamId`                     VARCHAR(36) NOT NULL,
+    `playerId`                   VARCHAR(36) NOT NULL,
+    `tries`                      INT         NOT NULL DEFAULT 0,
